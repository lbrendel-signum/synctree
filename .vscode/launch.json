    "version": "0.2.0",
    "configurations": [
        {
            "name": "Custom Args",
            "type": "debugpy",
            "request": "launch",
            "module": "synctree.cli",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": "${command:pickArgs}"
        },
        {
            "name": "Sync",
            "type": "debugpy",
            "request": "launch",
            "module": "synctree.cli",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "sync",
                "-v",
            ]
        },
        {
            "name": "Add Digikey",
            "type": "debugpy",
            "request": "launch",
            "module": "synctree.cli",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "add",
                "-s",
                "digikey",
            ]
        }
    ]
}